    {
      "nav_label": "Reduktion",
      "slides": [
        {
          "title": "Die Ausgangslage: das ganze Land",
          "subtitle": "38 GB, jede Fahrt der Schweiz",
          "content": [
            {
              "type": "figures",
              "items": [
                {
                  "value": "38 GB",
                  "label": "komprimierte Archiv-ZIPs",
                  "sentiment": "neutral"
                },
                {
                  "value": "~400",
                  "label": "Transportunternehmen CH",
                  "sentiment": "neutral"
                },
                {
                  "value": "5",
                  "label": "Verkehrsmittel-Arten",
                  "sentiment": "neutral"
                }
              ]
            },
            {
              "type": "statement",
              "sentiment": "neutral",
              "text": "Die IST-Rohdaten beschreiben den gesamten öffentlichen Verkehr der Schweiz — jeder Zug, Bus, jedes Tram, Schiff, jede Seilbahn. Relevant ist ein schmaler Ausschnitt: VBZ Tram Zürich."
            }
          ]
        },
        {
          "title": "Werkzeugwahl: Polars statt Pandas",
          "subtitle": "Auf den echten Daten gemessen, nicht angenommen",
          "content": [
            {
              "type": "comparison_table",
              "columns": [
                "",
                "Pandas",
                "Polars",
                "Faktor"
              ],
              "rows": [
                {
                  "cells": [
                    "Ladezeit (alle Parquets)",
                    "25,7 s",
                    "6,6 s",
                    "~4×"
                  ],
                  "highlight": false
                },
                {
                  "cells": [
                    "RAM-Verbrauch",
                    "6,1 GB",
                    "~1,4 GB",
                    "~4×"
                  ],
                  "highlight": true
                }
              ]
            },
            {
              "type": "statement",
              "sentiment": "positive",
              "text": "Entscheidung: Polars für alle großen Operationen (IST, Merge). Pandas bleibt für kleine Quellen (GTFS/Meteo/Events) und als Lernreferenz."
            }
          ]
        },
        {
          "title": "Von der Schweiz zu VBZ Tram",
          "subtitle": "Jede Filter-Entscheidung begründet",
          "content": [
            {
              "type": "steps",
              "items": [
                {
                  "step": "1",
                  "label": "Betreiber & Produkt",
                  "detail": "~400 CH-Unternehmen → BETREIBER_ID 85:3849 (VBZ), PRODUKT_ID = Tram"
                },
                {
                  "step": "2",
                  "label": "Zeitraum & Format",
                  "detail": "2023–2025, nur Format v1 (v2 ab Mitte 2025 ausgeklammert)"
                },
                {
                  "step": "3",
                  "label": "Messqualität",
                  "detail": "nur REAL-GPS-Messungen; Durchfahrten & Zusatzfahrten raus"
                },
                {
                  "step": "4",
                  "label": "Ausfälle behalten",
                  "detail": "FAELLT_AUS_TF = true bewusst drin — extremster Verspätungsfall"
                },
                {
                  "step": "5",
                  "label": "Spalten",
                  "detail": "21 Rohfelder → 10 (KEEP_COLS); Delays & stop_sequence abgeleitet"
                }
              ]
            },
            {
              "type": "statement",
              "sentiment": "neutral",
              "text": "~11 % der Zeilen entfernt — übrig bleiben echte, planmäßige Halte mit GPS-Zeitstempeln, plus alle Ausfälle."
            }
          ]
        }
      ]
    },
    {
      "nav_label": "Anreicherung",
      "slides": [
        {
          "title": "Tram-Halte allein erklären wenig",
          "subtitle": "Was macht Verspätung überhaupt nachvollziehbar?",
          "content": [
            {
              "type": "statement",
              "sentiment": "neutral",
              "text": "Ein Tram-Halt mit einer Verspätungszahl erklärt für sich genommen wenig. Erst der Kontext — Fahrplan, Wetter, Events, Geografie — macht Verspätung nachvollziehbar."
            },
            {
              "type": "statement",
              "sentiment": "positive",
              "text": "Also: vier gezielt recherchierte Zusatzquellen identifizieren und in den Master integrieren."
            }
          ]
        },
        {
          "title": "Anreicherung 1 — GTFS (Fahrplan)",
          "subtitle": "woher · was zu tun · wie übernommen",
          "content": [
            {
              "type": "sections",
              "items": [
                {
                  "label": "Woher",
                  "points": [
                    "data.stadt-zuerich.ch · ZIP/TXT · CC0",
                    "3 Jahrgänge, gesamtes ZVV-Netz"
                  ]
                },
                {
                  "label": "Was zu tun",
                  "points": [
                    "Auf VBZ-Tram-Linien filtern, 2024 als Primärreferenz",
                    "10+ GTFS-Tabellen → 4 Parquets (routes, stops, shapes, trips)"
                  ]
                },
                {
                  "label": "Wie übernommen",
                  "points": [
                    "Join über bpuic (Haltestellen-ID) → stop_name, stop_lat, stop_lon",
                    "+3 Spalten im Master"
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "Anreicherung 2 — Meteo (Wetter)",
          "subtitle": "woher · was zu tun · wie übernommen",
          "content": [
            {
              "type": "sections",
              "items": [
                {
                  "label": "Woher",
                  "points": [
                    "data.stadt-zuerich.ch (UGZ, Wapo, ERZ) · CSV/Parquet · CC0",
                    "3 Quellen, unterschiedliche Auflösung"
                  ]
                },
                {
                  "label": "Was zu tun",
                  "points": [
                    "Auf ein stündliches Raster konsolidieren",
                    "2 Referenzstationen: Stampfenbachstrasse (Stadtlage) + Mythenquai (Seelage)"
                  ]
                },
                {
                  "label": "Wie übernommen",
                  "points": [
                    "floor(1h) als Join-Schlüssel zu den Tram-Zeitstempeln",
                    "+7 Spalten (u.a. temperature, precipitation, wind_speed, flood_intensity)"
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "Anreicherung 3 — Events (der harte Fall)",
          "subtitle": "Kein Open Data — von Hand aufgebaut",
          "content": [
            {
              "type": "sections",
              "items": [
                {
                  "label": "Woher",
                  "points": [
                    "Keine strukturierte Open-Data-Quelle verfügbar",
                    "Manueller Crawl: Gemini, Perplexity, Transfermarkt"
                  ]
                },
                {
                  "label": "Was zu tun",
                  "points": [
                    "Schwellenwert > 1.000 Besucher, Stadt Zürich, 2023–2025",
                    "FCZ/GC-Spiele, Street Parade, Züri Fäscht …"
                  ]
                },
                {
                  "label": "Wie übernommen",
                  "points": [
                    "Als CSV aufgebaut, Join über das Datum",
                    "+4 Spalten (event_name, event_type, event_size, event_location)"
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "Anreicherung 4 — Geo (Stadtkreise)",
          "subtitle": "woher · was zu tun · wie übernommen",
          "content": [
            {
              "type": "sections",
              "items": [
                {
                  "label": "Woher",
                  "points": [
                    "data.stadt-zuerich.ch · GeoJSON · CC0",
                    "Stadtkreis-Grenzen, sofort verwendbar"
                  ]
                },
                {
                  "label": "Was zu tun",
                  "points": [
                    "Jeder Haltestelle ihren Stadtkreis zuordnen"
                  ]
                },
                {
                  "label": "Wie übernommen",
                  "points": [
                    "Spatial Join (Punkt-in-Polygon) auf die GTFS-Stops → district_nr, district_name",
                    "+2 Spalten — bereits im Master, kein nachträglicher Join in der EDA nötig"
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "nav_label": "Vereinigung",
      "slides": [
        {
          "title": "Die Join-Pipeline",
          "subtitle": "Vier Quellen, drei Joins, eine Qualitätsprüfung",
          "content": [
            {
              "type": "chart_refs",
              "items": [
                {
                  "label": "Master-Preparation Pipeline",
                  "source": "vbz_preparation.svg",
                  "caption": "Vier Quellen → drei Joins → Qualitätsprüfung → vbz_master.parquet."
                }
              ]
            }
          ]
        },
        {
          "title": "Left Joins — kein Zeilenverlust",
          "subtitle": "Die wichtigste Join-Entscheidung",
          "content": [
            {
              "type": "statement",
              "sentiment": "neutral",
              "text": "Left Join überall: jede Tram-Fahrt bleibt erhalten. Fehlende Werte (Sensor-Ausfall, Event-freier Tag) werden null — statt die Zeile zu löschen."
            },
            {
              "type": "statement",
              "sentiment": "positive",
              "text": "Datenverlust durch Join ist der häufigste stille Bug in Merge-Pipelines. Left Join macht ihn unmöglich."
            }
          ]
        },
        {
          "title": "Die Tücken im Detail",
          "subtitle": "Zwei Stolpersteine beim Join",
          "content": [
            {
              "type": "contrasts",
              "items": [
                {
                  "assumption": "Zwei Parquets mit datetime-Spalten joinen einfach",
                  "finding": "Meteo via pl.from_pandas → datetime[ns], IST nativ datetime[us]. Polars wirft SchemaError beim Join auf den stundengerundeten Schlüssel. Fix: explizit auf pl.Datetime('us') casten."
                },
                {
                  "assumption": "Stündliches Wetter passt direkt zu Tram-Zeitstempeln",
                  "finding": "Tram-Halte sind sekundengenau, Wetter stündlich. floor(1h) auf beiden Seiten erzeugt den gemeinsamen Join-Schlüssel."
                }
              ]
            }
          ]
        }
      ]
    },
