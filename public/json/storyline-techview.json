    {
      "nav_label": "Reduktion",
      "slides": [
        {
          "title": "Schweiz ÖPNV IST-Daten",
          "subtitle": "38 GB Daten für jede Fahrt (Halt) müssen reduziert werden",
          "content": [
            {
              "type": "figures",
              "items": [
                {
                  "value": "38 GB",
                  "label": "komprimierte Archiv-ZIPs",
                  "sentiment": "neutral"
                },
                {
                  "value": "~400",
                  "label": "Transportunternehmen CH",
                  "sentiment": "neutral"
                },
                {
                  "value": "5",
                  "label": "Verkehrsmittel-Arten",
                  "sentiment": "neutral"
                }
              ]
            },
            {
              "type": "statement",
              "sentiment": "neutral",
              "text": "Die IST-Rohdaten beschreiben den gesamten öffentlichen Verkehr der Schweiz — jeder Zug, Bus, jedes Tram, Schiff, jede Seilbahn. Relevant ist ein schmaler Ausschnitt: VBZ Tram Zürich."
            }
          ]
        },
        {
          "title": "Polars statt Pandas",
          "subtitle": "Vergleich und Entscheidung des passenden Werkzeugs",
          "content": [
            {
              "type": "comparison_table",
              "columns": [
                "",
                "Pandas",
                "Polars",
                "Faktor"
              ],
              "rows": [
                {
                  "cells": [
                    "Ladezeit (alle Parquets)",
                    "25,7 s",
                    "6,6 s",
                    "~4×"
                  ],
                  "highlight": false
                },
                {
                  "cells": [
                    "RAM-Verbrauch",
                    "6,1 GB",
                    "~1,4 GB",
                    "~4×"
                  ],
                  "highlight": false
                }
              ]
            },
            {
              "type": "statement",
              "sentiment": "positive",
              "text": "Entscheidung: Polars für alle großen Operationen (IST, Merge). Pandas bleibt für kleine Quellen (GTFS/Meteo/Events) und als Lernreferenz."
            }
          ]
        },
        {
          "title": "Benchmark im Detail",
          "subtitle": "Warum Polars — und wie der Wechsel funktioniert",
          "content": [
            {
              "type": "steps",
              "items": [
                {
                  "step": "1",
                  "label": "Messung auf echten Daten",
                  "detail": "Benchmark auf dem realen IST-Datensatz (~88 Mio Zeilen), nicht auf Spielzeugdaten"
                },
                {
                  "step": "2",
                  "label": "Warum Pandas anstößt",
                  "detail": "Bei dieser Größe am RAM-Limit (6,1 GB) — keine Lazy Evaluation"
                },
                {
                  "step": "3",
                  "label": "Polars-Vorteil",
                  "detail": "Query-Planung + Streaming: scan_parquet('*.parquet') liest ~1.035 Tages-Parquets als einen Datensatz"
                },
                {
                  "step": "4",
                  "label": "Brücke",
                  "detail": "pl.from_pandas() / df.to_pandas() für den Wechsel zwischen kleinen und großen Operationen"
                }
              ]
            }
          ]
        },
        {
          "title": "Von der Schweiz zu VBZ Tram",
          "subtitle": "Jede Filter-Entscheidung begründet",
          "content": [
            {
              "type": "steps",
              "items": [
                {
                  "step": "1",
                  "label": "Betreiber & Produkt",
                  "detail": "~400 CH-Unternehmen → BETREIBER_ID 85:3849 (VBZ), PRODUKT_ID = Tram"
                },
                {
                  "step": "2",
                  "label": "Zeitraum & Format",
                  "detail": "2023–2025, nur Format v1 (v2 ab Mitte 2025 ausgeklammert)"
                },
                {
                  "step": "3",
                  "label": "Messqualität",
                  "detail": "nur REAL-GPS-Messungen; Durchfahrten & Zusatzfahrten raus"
                },
                {
                  "step": "4",
                  "label": "Ausfälle behalten",
                  "detail": "FAELLT_AUS_TF = true bewusst drin — extremster Verspätungsfall"
                },
                {
                  "step": "5",
                  "label": "Spalten",
                  "detail": "21 Rohfelder → 10 (KEEP_COLS); Delays & stop_sequence abgeleitet"
                }
              ]
            },
            {
              "type": "statement",
              "sentiment": "neutral",
              "text": "~11 % der Zeilen entfernt — übrig bleiben echte, planmäßige Halte mit GPS-Zeitstempeln, plus alle Ausfälle."
            }
          ]
        }
      ]
    },
