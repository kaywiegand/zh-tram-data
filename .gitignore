# .gitignore – Python / Data Science (uv + venv)
# ------------------------------------------------
# WICHTIG: Daten und Modelle NICHT in Git einchecken!
# uv.lock wird NICHT ignoriert – Lockfile gehört in Git!

# ── Daten ──────────────────────────────────────────────────────────────────
data/raw/
data/interim/
data/processed/
*.csv
*.xlsx
*.parquet
*.feather
*.h5
*.hdf5

# ── Modelle & Artefakte ────────────────────────────────────────────────────
models/
*.pkl
*.joblib
*.pt
*.pth

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so

# ── Virtuelle Umgebung (uv erstellt .venv/) ────────────────────────────────
.venv/
.env
*.env

# ── Jupyter ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_metadata

# ── Appendix-Notebooks (Explorationsmaterial, schwere Map-Outputs) ──────────
# Lokal behalten, aber nicht im öffentlichen Repo (folium/plotly ~11 MB Blobs).
notebooks/appendix/

# ── Explorations-PDFs (geopandas-Maps) — lokal behalten, nicht im Repo ──────
public/img/*.pdf

# ── Portfolio-Pipeline Build-Snapshots (public/archive/vN/) — nicht ins Git ──
public/archive/

# ── IDE & OS ───────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Public (optional – kommentiere aus, wenn du Public-Artefakte tracken willst) ───
# public/img/
# public/md/
